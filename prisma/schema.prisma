generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CITIZEN
  AUTHORITY
  ADMIN
  CONTRACTOR
  EMERGENCY_OPERATOR
}

enum VoteType {
  UPVOTE
  SEVERITY_CONFIRM
}

enum HospitalType {
  GENERAL
  MULTISPECIALTY
  TRAUMA
}

enum HealthFacilityKind {
  HOSPITAL
  FIRST_AID
  TRAUMA_CENTER
}

enum EmergencyVehicleType {
  AMBULANCE
  FIRE_ENGINE
  PRIVATE_CAR
  TWO_WHEELER
}

enum IssueType {
  POTHOLE
  GARBAGE
  SEWAGE
  WATER_LEAK
  WATERLOGGING
  STREETLIGHT
  ROAD_DAMAGE
  TRAFFIC_SIGNAL
  FALLEN_TREE
  OTHER
}

enum IssueStatus {
  REPORTED
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  VERIFIED
  REJECTED
  MERGED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  ISSUE_UPDATE
  VERIFICATION_REQUEST
  STATUS_CHANGE
  SYSTEM
}

enum TenderStatus {
  DRAFT
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  supabaseId    String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CITIZEN)
  reputation    Int       @default(0)
  badges        String[]  @default([])
  phone         String?
  wardId        String?
  ward          Ward?     @relation(fields: [wardId], references: [id])

  issues         Issue[]        @relation("ReportedIssues")
  assignedIssues Issue[]        @relation("AssignedIssues")
  verifications  Verification[]
  comments       Comment[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  watchlists     Watchlist[]
  issueVotes     IssueVote[]
  statusChanges  IssueStatusHistory[] @relation("StatusChanger")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([role])
  @@index([wardId])
}

model Ward {
  id        String   @id @default(cuid())
  name      String
  number    Int      @unique
  zone      String
  latitude  Float
  longitude Float
  users        User[]
  issues       Issue[]
  roadSegments RoadSegment[]
  createdAt    DateTime @default(now())
}

model RoadSegment {
  id             String    @id @default(cuid())
  name           String
  wardId         String?
  ward           Ward?     @relation(fields: [wardId], references: [id])
  roadClass      String    @default("primary")
  latitudeStart  Float
  longitudeStart Float
  latitudeEnd    Float
  longitudeEnd   Float
  healthScore    Int       @default(100)
  lastScoredAt   DateTime?
  issues         Issue[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([wardId])
  @@index([healthScore])
}

model Issue {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        IssueType
  status      IssueStatus @default(REPORTED)
  severity       Severity @default(MEDIUM)
  confidence     Float    @default(0)
  aiSummary      String?
  priorityScore  Float    @default(0)
  voteCount      Int      @default(0)

  imageUrl    String
  afterImageUrl String?

  latitude  Float
  longitude Float
  address   String?

  wardId        String?
  ward          Ward?         @relation(fields: [wardId], references: [id])
  roadSegmentId String?
  roadSegment   RoadSegment?  @relation(fields: [roadSegmentId], references: [id])

  reporterId String
  reporter   User   @relation("ReportedIssues", fields: [reporterId], references: [id])

  assigneeId String?
  assignee   User?   @relation("AssignedIssues", fields: [assigneeId], references: [id])

  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id])

  tenderId String?
  tender   Tender? @relation(fields: [tenderId], references: [id])

  duplicateOfId String?
  duplicateOf   Issue?  @relation("DuplicateIssues", fields: [duplicateOfId], references: [id])
  duplicates    Issue[] @relation("DuplicateIssues")

  reportCount Int @default(1)

  verifications  Verification[]
  comments       Comment[]
  activityLogs   ActivityLog[]
  detection      IssueDetection?
  votes          IssueVote[]
  statusHistory  IssueStatusHistory[]

  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([type])
  @@index([severity])
  @@index([wardId])
  @@index([latitude, longitude])
  @@index([reporterId])
  @@index([createdAt])
  @@index([priorityScore])
  @@index([roadSegmentId])
  @@index([wardId, status, priorityScore])
}

model IssueDetection {
  id               String    @id @default(cuid())
  issueId          String    @unique
  issue            Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  modelProvider    String
  modelVersion     String?
  detectedCategory IssueType
  confidence       Float
  severityHint     Severity?
  rawResponse      Json?
  createdAt        DateTime  @default(now())

  @@index([detectedCategory])
}

model IssueVote {
  id                   String    @id @default(cuid())
  issueId              String
  issue                Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  voteType             VoteType  @default(UPVOTE)
  severityConfirmation Severity?
  createdAt            DateTime  @default(now())

  @@unique([issueId, userId])
  @@index([issueId])
}

model IssueStatusHistory {
  id              String       @id @default(cuid())
  issueId         String
  issue           Issue        @relation(fields: [issueId], references: [id], onDelete: Cascade)
  changedByUserId String?
  changedBy       User?        @relation("StatusChanger", fields: [changedByUserId], references: [id], onDelete: SetNull)
  fromStatus      IssueStatus?
  toStatus        IssueStatus
  note            String?
  createdAt       DateTime     @default(now())

  @@index([issueId])
  @@index([createdAt])
}

model Hospital {
  id           String             @id @default(cuid())
  name         String
  type         HospitalType       @default(GENERAL)
  kind         HealthFacilityKind @default(HOSPITAL)
  hasIcu       Boolean            @default(false)
  hasEmergency Boolean            @default(true)
  phone        String?
  address      String?
  briefInfo    String?
  latitude     Float
  longitude    Float
  open247      Boolean            @default(true)
  metadata     Json?
  createdAt    DateTime           @default(now())

  @@index([hasIcu])
  @@index([hasEmergency])
  @@index([kind])
  @@index([latitude, longitude])
}

model RouteRequest {
  id                    String                @id @default(cuid())
  requestedByUserId     String?
  sourceLat             Float
  sourceLng             Float
  destLat               Float
  destLng               Float
  vehicleType           EmergencyVehicleType?
  destinationHospitalId String?
  selectedRouteType     String?
  result                Json?
  createdAt             DateTime              @default(now())

  @@index([createdAt])
  @@index([destinationHospitalId])
}

model Verification {
  id           String             @id @default(cuid())
  issueId      String
  issue        Issue              @relation(fields: [issueId], references: [id], onDelete: Cascade)
  verifierId   String
  verifier     User               @relation(fields: [verifierId], references: [id])
  imageUrl     String
  status       VerificationStatus @default(PENDING)
  confidence   Float              @default(0)
  aiReasoning  String?
  latitude     Float?
  longitude    Float?
  geoValidated Boolean            @default(false)
  createdAt    DateTime           @default(now())

  @@index([issueId])
  @@index([verifierId])
}

model Contractor {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  rating      Float    @default(0)
  completedJobs Int    @default(0)
  active      Boolean  @default(true)
  issues      Issue[]
  tenders     Tender[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tender {
  id           String       @id @default(cuid())
  title        String
  description  String?
  budget       Float?
  status       TenderStatus @default(DRAFT)
  wardId       String?
  contractorId String?
  contractor   Contractor?  @relation(fields: [contractorId], references: [id])
  issues       Issue[]
  deadline     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  issueId   String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@index([issueId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  issueId   String?
  issue     Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([issueId])
  @@index([createdAt])
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  latitude  Float
  longitude Float
  radiusKm  Float    @default(2)
  createdAt DateTime @default(now())

  @@index([userId])
}
